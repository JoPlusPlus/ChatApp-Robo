# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Dart files
*.dart text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows specific
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.keystore binary

# Gradle wrapper
gradlew text eol=lf
gradlew.bat text eol=crlf
